{
  "name": "LinkCleaner",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build:android": "cd android && ./gradlew bundleRelease",
    "build:ios": "cd ios && xcodebuild -workspace LinkCleaner.xcworkspace -scheme LinkCleaner -configuration Release",
    "clean": "cd android && ./gradlew clean && cd ../ios && rm -rf build"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "1.16.3",
    "@react-native/new-app-screen": "0.80.2",
    "@react-navigation/native": "7.1.16",
    "@react-navigation/native-stack": "7.3.23",
    "react": "19.1.0",
    "react-native": "0.80.2",
    "react-native-paper": "^5.14.5",
    "react-native-receive-sharing-intent": "2.0.0",
    "react-native-safe-area-context": "5.5.2",
    "react-native-screens": "4.13.1",
    "react-native-share": "12.1.1",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "7.28.0",
    "@babel/preset-env": "7.28.0",
    "@babel/runtime": "7.28.2",
    "@react-native-community/cli": "19.1.1",
    "@react-native-community/cli-platform-android": "19.0.0",
    "@react-native-community/cli-platform-ios": "19.0.0",
    "@react-native/babel-preset": "0.80.2",
    "@react-native/eslint-config": "0.80.2",
    "@react-native/metro-config": "0.80.2",
    "@react-native/typescript-config": "0.80.2",
    "@testing-library/react-native": "13.2.1",
    "@types/jest": "30.0.0",
    "@types/react": "19.1.9",
    "@types/react-test-renderer": "19.1.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "jest-transform-stub": "2.0.0",
    "prettier": "3.6.2",
    "react-test-renderer": "19.1.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "reactNativePermissionsIOS": [
    "AppTrackingTransparency"
  ]
}
